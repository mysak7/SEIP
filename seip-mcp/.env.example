# Copy to .env and fill in your values
AWS_REGION=eu-central-1
DYNAMODB_TABLE=dev-security-events
PATTERNS_TABLE=dev-seip-patterns

# AWS credentials — use one of:
#   (a) IAM role on EC2/EKS (recommended, no vars needed)
#   (b) Named profile: AWS_PROFILE=seip-dev
#   (c) Static keys (not recommended):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
